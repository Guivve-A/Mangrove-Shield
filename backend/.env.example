# OpenWeather API Key para datos de lluvia actual en Guayaquil
# Obtener en: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Stormglass API Key para la marea del Golfo de Guayaquil / Estero Salado
# Obtener en: https://www.stormglass.io/account
STORMGLASS_API_KEY=your_stormglass_api_key_here

# Firebase Service Account (base64 encoded for CI/CD)
# Set in Railway/GitHub Actions secrets, not here
FIREBASE_SERVICE_ACCOUNT_B64=your_firebase_b64_key_here

# Google Earth Engine Service Account (base64 encoded for CI/CD)
# Set in Railway/GitHub Actions secrets, not here
GEE_SERVICE_ACCOUNT_B64=your_gee_service_account_b64_here

# Earth Engine Project ID
EE_PROJECT=studio-8904974087-7cc0a

# Optional: Custom Earth Engine URL
# EE_OPT_URL=https://earthengine-highvolume.googleapis.com

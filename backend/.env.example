# OpenWeather API Key para datos de lluvia actual en Guayaquil
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Stormglass API Key para la marea del Golfo de Guayaquil / Estero Salado
STORMGLASS_API_KEY=your_stormglass_api_key_here

# NOTA PARA GOOGLE EARTH ENGINE:
# Earth Engine NO requiere una llave de API en el archivo .env usualmente.
# En su lugar, debes autenticarte en tu máquina local. Abre la terminal en esta carpeta y ejecuta:
# earthengine authenticate
# 
# Si el proyecto en GCP te lo pide:
# earthengine set_project NOMBRE_DE_TU_PROYECTO_EN_GCP
